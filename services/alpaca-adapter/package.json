{
  "name": "@alpaca-rl/alpaca-adapter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@alpaca-rl/config": "workspace:*",
    "@alpaca-rl/contracts": "workspace:*",
    "@alpaca-rl/observability": "workspace:*",
    "@alpacahq/alpaca-trade-api": "^3.1.3",
    "@opentelemetry/api": "~1.8.0",
    "prom-client": "^15.1.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.51.0",
    "@opentelemetry/sdk-node": "^0.51.0",
    "fastify": "^4.27.0",
    "nats": "^2.18.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=19"
  }
}
